PORT=3001
NODE_ENV=development

# Firebase Admin SDK - leave blank to run without Firebase (mock mode)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# External Railway APIs - leave blank to use built-in mock data
# INDIAN_RAIL_API_KEY=
# RAIL_YATRI_API_KEY=

# Cache TTL in seconds
CACHE_TTL=60

# Mock mode - set to true to always use mock data regardless of API keys
USE_MOCK_DATA=true
